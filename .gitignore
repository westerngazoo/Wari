# Build artifacts
**/target/
/build/*
!/build/.gitkeep
# Exception: the deploy artifact must be committed so the VF2 can pull
# it via `wari go` (matches goose-os's deploy pattern).
!/build/wari.release

# rustc crash dumps — R8 says reproducible builds, ICE dumps are not
rustc-ice-*.txt

# Editor / OS noise
.vscode/
.idea/
*.swp
.DS_Store

# QEMU runtime debris
*.pcap
*.img.tmp

# PR body scratch (written by agent, consumed by `gh pr create` or web UI)
/pr-body.md
/pr*-body.md
